// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  userId String @id @default(uuid())
  username String @unique
  password String
}


enum OrderSide {
  buy
  sell
}

enum OrderType {
  limit
  market
}

enum OrderStatus {
  open
  filled
  cancelled
  partially_filled
}

model Order{
  orderId String @id @default(uuid())
  userId String 
  market String
  side OrderSide
  qty Int
  margin Int
  orderType OrderType
  price Int
  status OrderStatus
  createdAt String
}


enum PositionStatus {
  open
  closed
}

enum PositionType {
  long
  short
}

model Fills {
  fillsId String @id @default(uuid())
  side PositionType
  maker String
  taker String
  market String
  qty Int
  price Int
  long String
  short String
  positionStatus PositionStatus
  createdAt String
}

model Market {
  
}

model Balance {
  userId    String @id
  available Float
  locked    Float
}
//snapshot of the orderbook