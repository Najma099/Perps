generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId    String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  balance   Balance?
  orders    Order[]
  positions Position[]
}

enum OrderSide {
  buy
  sell
}

enum OrderType {
  limit
  market
}

enum OrderStatus {
  open
  filled
  partially_filled
  cancelled
}

model Order {
  orderId       String      @id @default(uuid())
  correlationId String      @unique
  userId        String
  market        String
  side          OrderSide
  qty           Float
  price         Float
  leverage      Float
  orderType     OrderType
  status        OrderStatus @default(open)
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [userId])
  fills         Fill[]
}

enum PositionSide {
  long
  short
}

model Fill {
  fillId    String    @id @default(uuid())
  orderId   String
  market    String
  side      OrderSide
  qty       Float
  price     Float
  maker     String
  taker     String
  createdAt DateTime  @default(now())

  order     Order     @relation(fields: [orderId], references: [orderId])
}

model Position {
  positionId       String         @id @default(uuid())
  userId           String
  market           String
  type             PositionSide
  qty              Float
  margin           Float
  leverage         Float
  averagePrice     Float
  liquidationPrice Float
  realizedPnl      Float          @default(0)
  positionStatus   String
  createdAt        DateTime       @default(now())
  closedAt         DateTime?

  user             User           @relation(fields: [userId], references: [userId])
}

model Balance {
  userId    String   @id
  available Float
  locked    Float
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [userId])
}

model Market {
  id     String @id @default(uuid())
  symbol String @unique
  slug   String @unique
}

model Candle {
  market String
  bucket Int      // unix seconds, minute-aligned
  open   Float
  high   Float
  low    Float
  close  Float

  @@unique([market, bucket])
  @@index([market, bucket])
}